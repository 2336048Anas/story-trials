// prisma/schema.prisma

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

/**
 * ---------------- Enums ----------------
 */

enum UserRole {
  CONTRIBUTOR // patients / labs
  BUYER // researchers
  ADMIN
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LicenseStatus {
  ISSUED
  REVOKED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

// NOTE: Currency enum is for SYNTHETIC DATA DEMONSTRATION ONLY.
// No real financial transactions occur. All payment tracking is for
// technical exploration of consent-based compensation models.
enum Currency {
  USD
  EUR
  GBP
}

/**
 * --------------- Models ---------------
 */

// Platform users (contributors, buyers, admin)
model User {
  id                String         @id @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  email             String?        @unique
  name              String?
  role              UserRole       @default(CONTRIBUTOR)
  walletAddress     String?        @unique // EVM address (0x...)
  royaltiesReceived RoyaltyEvent[] // back-relation for RoyaltyEvent.recipient

  // Relationships
  assets      DataAsset[]
  submissions Submission[]
  purchases   License[]    @relation("BuyerLicenses")
  payouts     Payout[]
  Trial       Trial[]

  @@index([role])
  @@index([walletAddress])
}

// A buyer-defined request for data (e.g., "7 days of sleep data")
model Trial {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  description String?
  // SYNTHETIC DATA ONLY: Display-only reward amount for demonstration purposes.
  // No real financial transactions occur. Used to explore optional compensation models
  // in consent-based data contribution systems.
  rewardUsd   Int // cents (demonstration only)
  isOpen      Boolean  @default(true)

  // Who posted this trial (usually a BUYER)
  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Restrict)

  submissions Submission[]

  @@index([isOpen])
  @@index([buyerId])
}

// Contributor-owned dataset that can be licensed (pointer only — data off-chain in IPFS)
model DataAsset {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  title       String
  description String?
  ipfsCid     String
  metadataCid String
  termsRef    String?
  isListed    Boolean  @default(true)

  // Story fields...
  ipAssetId    String?
  storyChainId Int?
  storyTxHash  String?

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  licenses    License[]
  // ✅ ADD this back-relation so Submission.asset has an opposite field
  submissions Submission[] // <— new

  @@index([ownerId])
  @@index([isListed])
  @@index([ipAssetId])
}

// A submission of data to a specific trial (can link to a DataAsset or just a CID)
model Submission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  trialId   String
  dataCid   String

  // Optional link to an existing DataAsset
  assetId String?
  // ✅ Make the relation field optional to match assetId
  asset   DataAsset? @relation(fields: [assetId], references: [id])

  status SubmissionStatus @default(PENDING)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trial Trial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trialId])
  @@index([status])
  @@index([assetId])
}

// A license purchased by a BUYER for a DataAsset
model License {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  status         LicenseStatus @default(ISSUED)
  assetId        String
  buyerId        String
  txHash         String? // on-chain tx that minted the license
  expiresAt      DateTime? // optional expiration
  chainLicenseId String? // optional on-chain license/token identifier

  asset     DataAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  buyer     User           @relation("BuyerLicenses", fields: [buyerId], references: [id], onDelete: Restrict)
  payment   Payment?
  royalties RoyaltyEvent[]
  // If you want only one active license per buyer+asset:
  // @@unique([assetId, buyerId])

  @@index([assetId])
  @@index([buyerId])
  @@index([status])
  @@index([chainLicenseId])
}

// SYNTHETIC DATA ONLY: Payment tracking for demonstration purposes.
// This model explores consent-based compensation models using synthetic data.
// No real financial transactions occur in this system.
model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  licenseId String   @unique
  amount    Int // minor units (synthetic demonstration value)
  currency  Currency @default(USD) // mock currency for technical exploration
  chainTx   String? // on-chain payment tx hash if applicable

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
}

// SYNTHETIC DATA ONLY: Royalty split tracking for demonstration purposes.
// This model explores how compensation could be distributed in consent-based systems.
// No real financial transactions occur.
model RoyaltyEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  licenseId   String
  recipientId String
  amount      Int // minor units (synthetic demonstration value)
  currency    Currency @default(USD) // mock currency for technical exploration
  note        String?

  // Link to payout batch when paid
  payoutId String?
  payout   Payout? @relation(fields: [payoutId], references: [id])

  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  recipient User    @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([licenseId])
  @@index([payoutId])
}

// SYNTHETIC DATA ONLY: Payout tracking for demonstration purposes.
// This model explores how compensation could be batched and distributed.
// No real financial transactions or bank transfers occur.
model Payout {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  recipientId String
  amount      Int // minor units (synthetic demonstration value)
  currency    Currency     @default(USD) // mock currency for technical exploration
  status      PayoutStatus @default(PENDING)
  reference   String? // mock reference for demonstration

  recipient User           @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  // Backref for events included in this payout
  events    RoyaltyEvent[]

  @@index([recipientId])
  @@index([status])
}
