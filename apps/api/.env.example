# ---- Database ----
DATABASE_URL="postgresql://story:story@localhost:5432/storytrials?schema=public"
SHADOW_DATABASE_URL="postgresql://story:story@localhost:5432/postgres?schema=public"

# ---- IPFS ----
# "local" stores files on disk; set to "remote" + IPFS_API_URL for a real IPFS node
IPFS_MODE=local
LOCAL_IPFS_DIR=../../.data/ipfs

# ---- Story Protocol ----
# Hex private key for the deployer/operator wallet (0x...)
# STORY_PRIVATE_KEY=0x...
# RPC endpoint (defaults to Aeneid testnet)
STORY_RPC_URL=https://aeneid.storyrpc.io
# SPG NFT contract address — deploy with: node scripts/setup-spg.mjs
# SPG_NFT_CONTRACT=0x...
# Set to "false" to use the real Story Protocol SDK (requires STORY_PRIVATE_KEY + SPG_NFT_CONTRACT)
DRY_RUN_STORY=true

# ---- Safety guards ----
# CRITICAL: System uses SYNTHETIC DATA ONLY for educational purposes.
# Payment/royalty models are for demonstration of consent-based compensation concepts.
ALLOW_REAL_PAYMENTS=false
